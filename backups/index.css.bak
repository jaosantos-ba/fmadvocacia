/* Full site CSS (restored) - styles for header, hero, sections, buttons */
:root{
	--bg:#ebe7e2;
	--text-dark:#211d1a;
	--accent:#a98652;
	--primary:#0b3d91;
	--muted:#6b7280;
	--line:rgba(70,55,36,0.14);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:Manrope,system-ui,-apple-system,"Segoe UI",Roboto,Arial;background:var(--bg);color:var(--text-dark);line-height:1.6}
img{display:block;max-width:100%;height:auto}
.container{width:min(1140px,calc(100% - 2rem));margin:0 auto}

/* Header / nav */
.site-header{position:sticky;top:0;z-index:1000;background:rgba(255,255,255,0.85);backdrop-filter:blur(8px);border-bottom:1px solid var(--line)}
.topbar{background:linear-gradient(90deg, rgba(43,46,51,0.94), rgba(63,67,74,0.92));color:#f3ece2;font-size:0.92rem}
.topbar-inner{min-height:3.2rem;display:flex;align-items:center;justify-content:space-between;padding:0 1rem}
.topbar-links{display:flex;gap:1rem}
.nav-shell{padding:0.6rem 0 0.9rem;background:linear-gradient(180deg, rgba(250,248,245,0.92), rgba(234,227,218,0.88))}
.nav{display:flex;align-items:center;justify-content:space-between;gap:1rem;min-height:4.9rem}
.brand img{width:220px;height:auto}
.nav-links{display:flex;gap:1.2rem;align-items:center}
.nav-links a{color:var(--text-dark);text-decoration:none;font-weight:600}
.social-links{display:flex;gap:0.6rem;align-items:center}
.social-links a{width:36px;height:36px;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(43,46,51,0.12);background:rgba(255,255,255,0.9)}

/* Buttons */
.button{display:inline-flex;align-items:center;justify-content:center;padding:0.7rem 1.2rem;border-radius:999px;border:0;font-weight:700;cursor:pointer}
.button-primary{background:linear-gradient(180deg,#c9ad81,#b29264);color:#261f17}
.button-secondary{background:linear-gradient(180deg,rgba(255,255,255,0.92),rgba(225,222,216,0.9));border:1px solid rgba(43,46,51,0.14)}

/* Hero */
.hero{padding:8rem 0 4rem}
.hero-grid{display:grid;grid-template-columns:1.2fr 0.8fr;gap:2rem;align-items:center}
.eyebrow{color:var(--accent);text-transform:uppercase;letter-spacing:0.12em;font-size:0.75rem;margin-bottom:0.8rem}
.hero-copy h1{font-family:Cinzel,serif;font-weight:600;font-size:clamp(2rem,4vw,3.6rem);margin-bottom:1rem}
.lead{color:#433d37;max-width:42rem}
.hero-panel{padding:2.2rem;border:1px solid var(--line);border-radius:1.2rem;background:linear-gradient(180deg,#fffdfa,#ece2d5)}

/* Sections */
.section{padding:4.5rem 0}
.intro-grid{display:grid;grid-template-columns:0.95fr 1.05fr;gap:2rem}
.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:1.8rem}
.card{padding:1.6rem;border-radius:1rem;border:1px solid var(--line);background:linear-gradient(135deg, rgba(65,69,76,0.04), transparent)}
.card-number{color:var(--accent);font-weight:700;display:inline-block;margin-bottom:0.8rem}

/* Contact / footer */
.contact-grid{display:grid;grid-template-columns:1fr 420px;gap:2rem}
.footer{padding:2rem 0;background:linear-gradient(180deg,#fff,#f3eee7);border-top:1px solid var(--line)}
.footer-inner{display:flex;align-items:center;justify-content:space-between}

/* Utilities */
.muted{color:var(--muted)}

@media (max-width:900px){
	.hero-grid{grid-template-columns:1fr}
	.cards{grid-template-columns:1fr}
	.nav{padding:0 0}
	.brand img{width:160px}
}

@media (max-width:480px){
	.topbar-inner{padding:0 0.8rem}
	.container{padding:0 12px}
}

/* Small helpers to ensure readable content when fonts fail to load */
h1,h2,h3{font-family: Cinzel, serif}

